# --- Telegram ---
# Токен бота от @BotFather (создай бота командой /newbot).
TELEGRAM_BOT_TOKEN=

# Кто может писать боту — твой Telegram user id (узнать у @userinfobot).
# Несколько — через запятую. ПУСТО = отвечать всем (НЕ оставляй пустым:
# чужие будут тратить твой лимит/баланс).
ALLOWED_USER_IDS=

# --- Доступ к модели ---
# Рекомендуется: подписка Claude Pro/Max (без оплаты за токены).
# На компьютере с браузером выполни `claude setup-token`, войди в аккаунт Claude
# и вставь выданный токен сюда:
CLAUDE_CODE_OAUTH_TOKEN=
# Запасной вариант, если подписки нет — API-ключ (оплата по использованию):
# ANTHROPIC_API_KEY=

# --- Необязательное ---
# Путь к дому агента. По умолчанию — папка на уровень выше bot.py.
# HERMES_HOME=/srv/hermes/workspace
# Модель (по умолчанию — то, что настроено в Claude Code).
# MODEL=claude-sonnet-4-6
# Таймаут одного ответа, сек.
# TIMEOUT=180
